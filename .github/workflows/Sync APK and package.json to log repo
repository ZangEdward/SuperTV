      # 同步 APK、package.json，并生成狗屁不通 log 文件（根目录）
      - name: Sync APK and package.json to log repo
        run: |
          TIMESTAMP=$(date +%s)
          LOGFILE="${TIMESTAMP}.log"

          git clone https://github.com/ZangEdward/internal-cache-sync-daemon-log.git sync-repo

          # 创建版本目录
          mkdir -p sync-repo/${VERSION}
          cp output/SuperTV-${VERSION}.apk sync-repo/${VERSION}/
          cp output/package.json sync-repo/${VERSION}/

          # 生成一万个随机字符
          RANDOM_CHARS=$(cat /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 10000)

          # 写入狗屁不通 log 文件
          {
            echo "Timestamp: ${TIMESTAMP}"
            echo "Sync Time: $(date '+%Y-%m-%d %H:%M:%S')"
            echo "Version: ${VERSION}"
            echo ""
            echo "Entropy-Seed: $((RANDOM * RANDOM))"
            echo "Quantum-Residue: 0x$(openssl rand -hex 3)"
            echo ""
            echo "Payload:"
            echo "XJ29A0D9-UNDEFINED-BUFFER-REWRITE-CHANNEL-Ω"
            echo "proto-sync-shadow: enabled-but-not-really"
            echo "cache-drift-index: 0.$((RANDOM)) / fluctuating"
            echo "daemon-murmur: \"the packet walks sideways tonight\""
            echo ""
            echo "Random-Block:"
            echo "${RANDOM_CHARS}"
            echo ""
            echo "Footer:"
            echo "this-log-file-was-generated-by-a-daemon-that-denies-its-own-existence"
          } > sync-repo/${LOGFILE}

          cd sync-repo
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add .
          git commit -m "Sync SuperTV v${VERSION} with absurd log ${LOGFILE}"
          git push https://ZangEdward:${{ secrets.PAT }}@github.com/ZangEdward/internal-cache-sync-daemon-log.git
